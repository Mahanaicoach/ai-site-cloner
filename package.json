    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
