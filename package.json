  "bugs": {
    "url": "https://github.com/Mahanaicoach/site-cloner/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
